void comment(int age) {
    if age < 18 {
        printf("You are minor\n");
        return;
    }
    printf("You are major\n");
}

int sum(int a, int b) { return a + b; }

int main() {
    int age = 10;
    while age < 18 {
        age++;
        printf("Getting old...\n");
        comment(age);
    }
    return 0;
}

if a >= ++b - 5 { a++; }
if a >= 5 {
    if b < a {
        b += 88;
    }
    a++;
}

while a >= ++b - 5 { a++; }
while a >= 5 {
    while b < a {
        b += 88;
    }
    a++;
}

for 0..10 { } // 0 to 10 

for 0>.10 { } // 1 to 10

for 0.<10 { } // 0 to 9

for 0><10 { } // 1 to 9

for a..b {
    a: int = it; // 'it' has the iterations count
}

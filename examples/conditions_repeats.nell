if (a >= ++b - 5) { a++; }
if a > 5 && a < 10 {
    if b > a || a < 8 {
        b += 88;
    }
    a++;
}

switch a {
    case 10 {
        a++;
        break;
    }
    default {
        a--;
        break;
    }
}

while a >= ++b - 5 { a++; }
while a > 5 && a < 10 {
    while b > a || a < 8 {
        b += 88;
    }
    a++;
}

for 0..10 { } // 0 to 10 

for 0>.10 { } // 1 to 10

for 0.<10 { } // 0 to 9

for 0><10 { } // 1 to 9

for a..b {
    a: int = it; // 'it' has the iterations count
}

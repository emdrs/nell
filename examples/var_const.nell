// Var definition
int a = 10;
int b = 10;
int c;

// Operators
c = a * b;
c = a / b;
c = a + b;
c = a - b;

// Assign operators
c *= 1;
c /= a;
c += b + 5;
c -= 1 + 2;

// Increment and decrement
c++;
--c;
c = b++;
c = --a - 5;

// Constants
const float PI = 3.1415;
const int YEAR = 2026;
const int NEXT_YEAR = 2026 + 1;
const int AGE = 15;

// Binary expressions
const int IS_TEEN = AGE < 18;
int is_adult = AGE >= 18;
int is_old = AGE > 65;
const int IS_CENTENARY = AGE == 100;

// Var definition
a: int;
a: int = 10;
b := a; // Implicit type (int)

// Operators
c := a * b;
d := a / b;
e := a + b;
f := a - b;

// Assign operators
f *= 1;
f /= a;
f += b + 5;
f -= 1 + 2;

// Increment and decrement
f++;
--f;
g = f++;
g := --f - 5;

// Constants
PI :: 3.1415;
YEAR :: 2026;
NEXT_YEAR :: 2026 + 1;

// Comparisons
IS_TEEN :: idade < 18;
is_adult := idade >= 18;
is_old: bool = idade > 65;
IS_CENTENARY :: idade == 100;

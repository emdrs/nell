// Var definition
a: int = 10;
b := a; // Implicit type (int)

// Operators
c := a * b;
d := a / b;
e := a + b;
f := a - b;

// Assign operators
f *= 1;
f /= a;
f += b + 5;
f -= 1 + 2;

// Increment and decrement
// f++;
g = f++;
g := --f - 5;

// Constants
PI :: 3.1415;
YEAR :: 2026;
NEXT_YEAR :: 2026 + 1;

// Var definition
int a;
int a = 10;

// Operators
c = a * b;
d = a / b;
e = a + b;
f = a - b;

// Assign operators
f *= 1;
f /= a;
f += b + 5;
f -= 1 + 2;

// Increment and decrement
f++;
--f;
g = f++;
g = --f - 5;

// Constants
const float PI = 3.1415;
const int YEAR = 2026;
const int NEXT_YEAR = 2026 + 1;

// Binary expressions
